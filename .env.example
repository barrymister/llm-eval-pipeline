# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Ollama endpoint
# Default for local dev: http://localhost:11434
# Default for Docker (appfactory host): http://10.0.1.1:11434
OLLAMA_BASE_URL=http://localhost:11434

# Models to evaluate by default (comma-separated)
# These are the models available on Barry's appfactory GPU (gemma3:12b, mistral-small3.2)
# Change to whatever models you have pulled in Ollama
DEFAULT_MODELS=gemma3:12b,mistral-small3.2

# Optional: Anthropic Claude API (for comparing local Ollama against Claude as baseline)
# Leave blank to use Ollama-only mode (no API costs)
ANTHROPIC_API_KEY=

# MLflow tracking server (auto-configured by docker-compose, change if running externally)
MLFLOW_TRACKING_URI=http://localhost:5000
